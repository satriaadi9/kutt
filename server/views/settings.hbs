{{> header}}
<section id="settings" class="section-container">
  <h1 class="settings-welcome">
    Welcome, <span>{{user.email}}</span>.
  </h1>
  <hr />
  {{#if user.admin}}
    {{> settings/domain/index}}
    <hr />
    {{> settings/apikey}}
    <hr />
  {{/if}}
  {{> settings/change_password}}
  <hr />
  {{#if user.admin}}
    {{#if mail_enabled}}
      {{> settings/change_email}}
      <hr />
    {{/if}}
    {{> settings/delete_account}}
  {{/if}}
</section>
{{> footer}}